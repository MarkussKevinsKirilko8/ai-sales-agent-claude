# Copy to .env and fill in real values on each server. Never commit .env.

# Telegram — bot 1 (test, AI-only) + bot 2 (production, has mini-app shop) +
# bot 3 (pre-existing bot getting the AI added — opt-in flow)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN_2=
TELEGRAM_BOT_TOKEN_3=

# Bots that are AI-only: no Manager button, no CRM events (comma-separated usernames)
AI_ONLY_BOTS=sales_ai_agent_claude_bot

# Bots that had existing users BEFORE the AI was added. First non-/start
# interaction is treated as an existing customer + "AI added" opt-in prompt.
OPT_IN_BOTS=

# Claude API (Anthropic)
CLAUDE_API_KEY=

# OpenAI (Whisper voice-to-text)
OPENAI_API_KEY=

# "New user joined" notification webhook (fleet notification service)
BOT_START_WEBHOOK_URL=
BOT_START_WEBHOOK_SECRET=

# Firecrawl (fallback scraper, currently disabled)
FIRECRAWL_API_KEY=

# Product API (catalog source)
PRODUCT_API_URL=
PRODUCT_API_TOKEN=

# OCTO CRM integration (bidirectional, HMAC-signed)
CRM_BASE_URL=
OCTO_API_KEY=
OCTO_SECRET=

# PostgreSQL
POSTGRES_USER=agent
POSTGRES_PASSWORD=
POSTGRES_DB=sales_agent
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Sync schedule (hours between product API syncs)
SCRAPE_INTERVAL_HOURS=6
